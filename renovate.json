{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "github>aquaproj/aqua-renovate-config#2.11.0"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["\\.nix$"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>[^\\n]+)\\n\\s*version\\s*=\\s*\"(?<currentValue>[^\"]+)\";"
      ],
      "extractVersionTemplate": "^v?(?<version>.+)$"
    }
  ],
  "nix": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchPackageNames": [
        "aquaproj/aqua",
        "aquaproj/aqua-installer"
      ],
      "automerge": true
    },
    {
      "matchFileNames": [
        "config/.config/aquaproj-aqua/aqua.yaml"
      ],
      "automerge": true
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "automerge": true
    },
    {
      "matchPackageNames": [
        "aquaproj/aqua-renovate-config"
      ],
      "automerge": true
    },
    {
      "matchManagers": [
        "custom.regex",
        "nix"
      ],
      "automerge": true
    }
  ]
}

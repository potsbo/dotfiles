Include ~/.ssh/config.d/*
IdentityFile ~/.ssh/id_ed25519

# Load the key into the agent on first use (and into the macOS keychain so it
# unlocks without a prompt). With ForwardAgent this lets intermediate hosts
# reuse the key without ever storing it there. IgnoreUnknown keeps UseKeychain
# from erroring on Linux, where it is not a valid option.
AddKeysToAgent yes
IgnoreUnknown UseKeychain
UseKeychain yes

Host mac-mini
  HostName mac-mini
  User shared

Host raptorlake-windows
  HostName raptorlake-windows

# Linux ホスト共通: open/xdg-open を手元の Mac で開くための opener 転送。
# 本命は TCP (Mac 側は launchd の opener-listen)。unix socket と違い、
# 短命な ssh 接続が長寿命接続 (herdr) のフォワードを unlink で壊さない。
# 後続の接続は bind に失敗するだけ (警告のみ) で無害。
# unix socket の行は旧方式 (superbrothers/opener)。移行が済んだら消す。
Host raptorlake tigerlake phoenix graniteridge
  ForwardAgent yes
  RemoteForward 127.0.0.1:2226 127.0.0.1:2226
  RemoteForward /home/potsbo/.opener.sock /Users/potsbo/.opener.sock

Host blizzard
  HostName blizzard
  ForwardAgent yes

Host github.com
  User git
  Port 22
  HostName github.com

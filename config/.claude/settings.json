{
  "agentPushNotifEnabled": true,
  "effortLevel": "medium",
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true
  },
  "env": {
    "CLAUDE_CODE_ENABLE_AUTO_MODE": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash '/home/potsbo/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "model": "claude-fable-5[1m]",
  "permissions": {
    "defaultMode": "auto",
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push * --force*)",
      "Bash(git push * -f*)",
      "Bash(git rebase*)"
    ]
  },
  "remoteControlAtStartup": true,
  "skipDangerousModePermissionPrompt": true,
  "tui": "fullscreen"
}
#!/usr/bin/env bash
# Pick any worktree across every ghq repo and switch to its herdr space,
# creating the space if none exists yet.
#
# One worktree <-> one space: keyed off the worktree's on-disk path. If an open
# space already has a pane rooted at that path we focus it, otherwise we create
# a new space there.
set -euo pipefail

ghq_root=$(ghq root)

# Display name for a worktree path. Inlined port of path-to-name.sh: strip the
# ghq root, swap the host for a nerd-font icon, and mark /.worktrees/. Kept as a
# shell function (not a subprocess per line) — spawning path-to-name.sh once per
# worktree dominated the runtime (~1.3s for a few hundred worktrees) and blocked
# fzf's incremental rendering.
ICON_OPEN=$(printf '\xe2\x97\x8f')   # ● marks a worktree that already has a space
ICON_GITHUB=$(printf '')
ICON_GITLAB=$(printf '')
ICON_WORKTREE=$(printf '')
name_of() {
  local rel="${1#"$ghq_root"/}"
  local host="${rel%%/*}" name="${rel#*/}"
  case "$host" in
    github.com) host=$ICON_GITHUB ;;
    gitlab.com) host=$ICON_GITLAB ;;
  esac
  name="${name/\/.worktrees\///$ICON_WORKTREE }"
  printf '%s %s' "$host" "$name"
}

# Snapshot of open panes, used to mark open worktrees and resolve the target
# workspace id after the pick. Taken once so the view is stable.
panes=$(herdr pane list)
open_cwds=$(printf '%s' "$panes" | jq -r '.result.panes[].cwd')

# All worktrees across all repos, "<path>\t<branch>", deduped by path.
# (Linked worktrees of the same repo are separate ghq entries and each reports
# the full worktree set, so the same path shows up many times without dedup.)
#
# Repos are visited most-recently-touched first (by .git/index mtime, same
# heuristic as worktree-new.sh), so frequently-used repos stream to the top of
# fzf immediately instead of waiting behind the whole ghq list. Dedup keeps the
# first occurrence, so each worktree inherits its owning repo's rank.
list_worktrees() {
  ghq list --full-path | while IFS= read -r repo; do
    t=$(stat -c %Y "$repo/.git/index" 2>/dev/null || stat -f %m "$repo/.git/index" 2>/dev/null || echo 0)
    printf '%s\t%s\n' "$t" "$repo"
  done | sort -rn | cut -f2- | while IFS= read -r repo; do
    git -C "$repo" worktree list --porcelain 2>/dev/null
  done | awk '
    /^worktree /  { p = substr($0, 10) }
    /^branch /    { b = $2; sub("refs/heads/", "", b); print p "\t" b }
    /^detached$/  { print p "\t(detached)" }
  ' | awk -F'\t' '!seen[$1]++'
}

openf=$(mktemp)
trap 'rm -f "$openf"' EXIT
printf '%s\n' "$open_cwds" >"$openf"

# fzf line: "<path>\t<mark> <display name>\t<branch>"; columns 2,3 shown.
#
# Worktrees that already have a space (● / present in $openf) are emitted first,
# so switching back to something already open is a near-instant top-of-list pick;
# the rest follow, each group keeping the most-recently-used order from
# list_worktrees. Closed lines are buffered and flushed after the open ones.
#
# Feed the list via process substitution rather than a pipe into fzf: picking
# before every line is loaded makes fzf exit and SIGPIPE the still-running
# generator, which under `pipefail` would surface as a non-zero pipeline status
# and silently trip the `|| exit 0` below (nothing happens). With `< <(...)` the
# command substitution's status is fzf's alone, so only a real cancel exits.
sel=$(
  fzf --delimiter='\t' --with-nth=2,3 \
      --prompt='space> ' \
      --preview='git -C {1} log --oneline --decorate -15 2>/dev/null' \
      --preview-window=right,50% \
    < <(
      deferred=''
      while IFS=$'\t' read -r path branch; do
        if grep -qxF "$path" "$openf"; then
          printf '%s\t%s %s\t%s\n' "$path" "$ICON_OPEN" "$(name_of "$path")" "$branch"
        else
          deferred+="$(printf '%s\t  %s\t%s' "$path" "$(name_of "$path")" "$branch")"$'\n'
        fi
      done < <(list_worktrees)
      printf '%s' "$deferred"
    )
) || exit 0

path=$(printf '%s' "$sel" | cut -f1)
[ -n "$path" ] || exit 0

ws=$(printf '%s' "$panes" | jq -r --arg p "$path" \
  'first(.result.panes[] | select(.cwd == $p) | .workspace_id) // empty')

if [ -n "$ws" ]; then
  herdr workspace focus "$ws"
else
  # `herdr worktree open` only works from a repo's parent workspace, so it can't
  # target an arbitrary linked-worktree path. A plain workspace rooted at the
  # worktree path gives us the 1:1 space we want without that restriction.
  herdr workspace create --cwd "$path" --label "$(name_of "$path")" --focus
fi

#!/usr/bin/env bash
# Assigned color for a host, as "#rrggbb" (single source of truth; used by the
# zsh FZF frame and the tuicast ssh view). Matching is on the short name, so
# "blizzard", "blizzard.local" and a full hostname all resolve the same.
case "${1%%.*}" in
  tigerlake)    echo "#fd971f" ;;
  raptorlake)   echo "#f8f8f2" ;;
  avalanche)    echo "#ae81ff" ;;
  phoenix)      echo "#d7875f" ;;
  staten-nix)   echo "#f92672" ;;
  blizzard)     echo "#55bed2" ;;
  graniteridge) echo "#a6e22e" ;;
  *)            echo "#797979" ;;
esac

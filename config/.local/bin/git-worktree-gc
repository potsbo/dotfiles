#!/usr/bin/env bash

# 古い git worktree を安全に削除する。
# 以下をすべて満たす linked worktree だけを消す:
#   - working tree がクリーン (未コミット変更・untracked なし)
#   - 未 push コミットなし (upstream に push 済み、または origin のデフォルトブランチに merge 済み)
#   - ディレクトリの mtime が MAX_AGE_DAYS 日より古い
# 使い方: git worktree-gc [--dry-run] [repo...]
#   repo 省略時は ~/src/github.com/*/* から primary worktree を自動検出

set -eu

MAX_AGE_DAYS="${MAX_AGE_DAYS:-30}"
DRY_RUN=0
[ "${1:-}" = "--dry-run" ] && { DRY_RUN=1; shift; }

repos=("$@")
if [ ${#repos[@]} -eq 0 ]; then
  for d in "$HOME"/src/github.com/*/*/; do
    # linked worktree は .git がファイルなので、.git がディレクトリの primary だけ対象
    [ -d "$d/.git" ] && repos+=("${d%/}")
  done
fi

now=$(date +%s)
removed=0 skipped=0

for repo in "${repos[@]}"; do
  worktrees=$(git -C "$repo" worktree list --porcelain | awk '/^worktree /{print substr($0,10)}' | tail -n +2)
  [ -z "$worktrees" ] && continue

  git -C "$repo" fetch origin --quiet 2>/dev/null || true
  default_branch=$(git -C "$repo" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null || echo origin/main)

  while IFS= read -r wt; do
    [ -d "$wt" ] || continue

    age_days=$(( (now - $(stat -c %Y "$wt")) / 86400 ))
    if [ "$age_days" -le "$MAX_AGE_DAYS" ]; then
      skipped=$((skipped + 1)); continue
    fi

    if [ -n "$(git -C "$wt" status --porcelain 2>/dev/null)" ]; then
      echo "skip (dirty): $wt"
      skipped=$((skipped + 1)); continue
    fi

    if ! git -C "$wt" merge-base --is-ancestor HEAD '@{u}' 2>/dev/null &&
       ! git -C "$wt" merge-base --is-ancestor HEAD "$default_branch" 2>/dev/null; then
      echo "skip (unpushed): $wt"
      skipped=$((skipped + 1)); continue
    fi

    branch=$(git -C "$wt" symbolic-ref --short HEAD 2>/dev/null || true)
    if [ "$DRY_RUN" = 1 ]; then
      echo "would remove: $wt (${age_days}d, branch=${branch:-detached})"
    else
      echo "remove: $wt (${age_days}d, branch=${branch:-detached})"
      git -C "$repo" worktree remove "$wt" || { skipped=$((skipped + 1)); continue; }
      [ -n "$branch" ] && git -C "$repo" branch -d "$branch" 2>/dev/null || true
      removed=$((removed + 1))
    fi
  done <<< "$worktrees"

  git -C "$repo" worktree prune
done

echo "done: removed=$removed skipped=$skipped"

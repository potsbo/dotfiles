#!/usr/bin/env bash

set -eu

if [[ $# -eq 0 ]]; then
  echo "Usage: warm <directory> [parallel_jobs]"
  echo "Recursively read all files to warm up cache"
  exit 1
fi

dir="$1"
default_jobs=$(($(nproc) * 2))
[[ "$default_jobs" -lt 1 ]] && default_jobs=1
jobs="${2:-$default_jobs}"

if [[ ! -d "$dir" ]]; then
  echo "Error: '$dir' is not a directory"
  exit 1
fi

list_cmd=(find "$dir" -type f)
count_cmd=(find "$dir" -type f)
if command -v fd >/dev/null; then
  list_cmd=(fd -t f -0 . "$dir")
  count_cmd=(fd -t f . "$dir")
fi

echo "Warming $dir with $jobs parallel jobs..."

if command -v pv >/dev/null; then
  # Count concurrently via named pipe - warming starts immediately
  count_pipe=$(mktemp -u)
  mkfifo "$count_pipe"
  trap 'rm -f "$count_pipe"' EXIT

  "${count_cmd[@]}" | wc -l > "$count_pipe" &

  if command -v fd >/dev/null; then
    "${list_cmd[@]}" | xargs -0 -P "$jobs" -I {} sh -c 'cat "$1" > /dev/null && printf "\n"' -- {} | pv -l -s "$(cat "$count_pipe")" > /dev/null
  else
    "${list_cmd[@]}" -print0 | xargs -0 -P "$jobs" -I {} sh -c 'cat "$1" > /dev/null && printf "\n"' -- {} | pv -l -s "$(cat "$count_pipe")" > /dev/null
  fi
else
  find "$dir" -type f -print0 | xargs -0 -P "$jobs" cat > /dev/null
fi

theme = Monokai Remastered

font-family = JetBrains Mono
font-style = Medium
font-family = Symbols Nerd Font Mono
font-codepoint-map = U+3000-U+9FFF=BIZ UDGothic
font-codepoint-map = U+FF00-U+FFEF=BIZ UDGothic
font-feature = -calt
font-feature = -liga
font-feature = -dlig

keybind = super+p=text:\x1b:CommandP\x0d
# VSCode like save in neovim
keybind = super+s=text:\x1b:w\x0d
# VSCode like split in neovim
keybind = super+\=text:\x1b:vsplit\x0d
# Reload current buffer in neovim
keybind = super+r=text:\x1b:e!\x0d

clipboard-read = allow
desktop-notifications = false

# Linux 固有設定を読み込む (xremap 用のキーバインド等)
config-file = config-linux

# macOS specific settings
macos-option-as-alt = left
macos-titlebar-style = hidden
